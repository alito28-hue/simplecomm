generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANT (empresa emisora) ──────────────────────────────────────────────
model Tenant {
  id                String       @id @default(cuid())
  code              String       @unique // ej: "mocla", "clubsorteos"
  name              String
  cuit              String       @unique
  defaultPtoVta     Int
  environment       AfipEnv      @default(PRODUCTION)
  status            TenantStatus @default(ACTIVE)
  address           String?      // Domicilio comercial, para el PDF
  iibb              String?      // N° de Ingresos Brutos (si difiere del CUIT)
  activityStartDate DateTime?    // Fecha de inicio de actividades
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  credential   TenantCredential?
  apiKeys      ApiKey[]
  authTickets  AuthTicket[]
  invoices     Invoice[]
  logs         ProviderLog[]

  @@map("tenants")
}

// ─── CREDENCIALES AFIP por tenant ─────────────────────────────────────────
model TenantCredential {
  id          String    @id @default(cuid())
  tenantId    String    @unique
  certEnc     String    @db.Text   // cert PEM cifrado con AES-256-GCM
  keyEnc      String    @db.Text   // clave privada PEM cifrada
  chainEnc    String    @db.Text   // cadena CA PEM cifrada
  fingerprint String                // SHA1 del cert para identificación rápida
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_credentials")
}

// ─── API KEYS ──────────────────────────────────────────────────────────────
model ApiKey {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  keyHash   String   @unique  // bcrypt hash de la clave real
  prefix    String            // primeros 8 chars en claro para identificar (ej: "sc_live_")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ─── TICKETS DE AUTORIZACIÓN (cache de WSAA) ──────────────────────────────
model AuthTicket {
  id        String   @id @default(cuid())
  tenantId  String
  service   String   @default("wsfe")
  token     String   @db.Text
  sign      String   @db.Text
  expiresAt DateTime
  signer    String   @default("pkijs") // qué signer generó este ticket
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("auth_tickets")
}

// ─── FACTURAS ─────────────────────────────────────────────────────────────
model Invoice {
  id             String    @id @default(cuid())
  tenantId       String
  idempotencyKey String    @unique
  ptoVta         Int
  invoiceType    Int       // 6 = Factura B
  invoiceNumber  Int?
  cae            String?
  caeDueDate     String?   // YYYYMMDD
  buyerDocType   Int       // 96 = DNI, 80 = CUIT, 99 = Consumidor Final
  buyerDocNumber String
  buyerName      String
  totalAmount    Decimal   @db.Decimal(12, 2)
  netAmount      Decimal   @db.Decimal(12, 2)
  ivaAmount      Decimal   @db.Decimal(12, 2)
  concept        Int       @default(1)   // 1=Productos, 2=Servicios, 3=Ambos
  moneda         String    @default("PES")  // "PES" o "DOL" (AFIP MonId)
  cotizacion     Decimal   @default(1) @db.Decimal(10, 4) // AFIP MonCotiz
  description    String?
  externalRef    String?
  status         InvStatus @default(PENDING)
  errorMessage   String?
  afipResponse   Json?
  sourceApp      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  artifact InvoiceArtifact?
  logs     ProviderLog[]

  @@map("invoices")
}

// ─── ARTEFACTOS (PDF) ─────────────────────────────────────────────────────
model InvoiceArtifact {
  id        String   @id @default(cuid())
  invoiceId String   @unique
  pdfBase64 String?  @db.Text   // PDF en base64 (para v1 sin storage externo)
  pdfSha256 String?
  pdfSizeKb Int?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_artifacts")
}

// ─── LOGS DE PROVEEDOR (auditoría completa) ───────────────────────────────
model ProviderLog {
  id        String   @id @default(cuid())
  tenantId  String
  invoiceId String?
  requestId String   // UUID por request para correlación
  stage     String   // "signer", "wsaa", "wsfe_dummy", "wsfe_issue", "pdf"
  signer    String?  // "pkijs" u otro
  success   Boolean
  message   String   @db.Text
  metadata  Json?    // request/response truncado (sin PEMs)
  durationMs Int?
  createdAt DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@map("provider_logs")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────
enum AfipEnv {
  PRODUCTION
  HOMOLOGATION
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum InvStatus {
  PENDING
  ISSUED
  ERROR
  CANCELLED
}
